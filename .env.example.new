# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./auto_publisher.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# GitHub 配置
GITHUB_TOKEN=your_github_token_here
GITHUB_FETCH_COUNT=100
GITHUB_DAYS_WINDOW=30

# LLM 配置
LLM_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_ENABLED=true

# 发布平台配置
NOTION_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
CSDN_PUBLISH_API=your_csdn_api_here
CSDN_TOKEN=your_csdn_token_here
ZHIHU_TOKEN=your_zhihu_token_here
JUEJIN_TOKEN=your_juejin_token_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 监控配置
MONITORING_ENABLED=true
METRICS_PORT=8000
DASHBOARD_PORT=8080

# 调度配置
SCHEDULE_CRON=0 9 * * *
TIMEZONE=Asia/Shanghai

# 模板配置
TEMPLATE_DIR=templates
DEFAULT_TEMPLATE=default.md.j2

# 日志配置
LOG_LEVEL=INFO
DEBUG=false

# 路径配置
REPORTS_DIR=reports
STATE_FILE=state/selection_state.json
